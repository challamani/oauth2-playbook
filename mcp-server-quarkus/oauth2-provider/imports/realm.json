{
  "realm": "oauth2-playbook",
  "enabled": true,

  "clients": [

    {
      "clientId": "oauth2-playbook-mcp-agent",
      "description": "Public PKCE client used by AI agents (Copilot, Cline, Cursor) to authenticate end users via Authorization Code + PKCE. Issues tokens with mcp:* scopes and audience oauth2-playbook-mcp-inventory.",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "bearerOnly": false,
      "redirectUris": [
        "*"
      ],
      "webOrigins": [
        "*"
      ],
      "defaultClientScopes": [
        "basic",
        "profile",
        "openid"
      ],
      "optionalClientScopes": [
        "mcp:events:read",
        "mcp:tickets:read",
        "mcp:reservations:write"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "mcp-inventory-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "oauth2-playbook-mcp-inventory",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "introspection.token.claim": "true",
            "userinfo.token.claim": "false"
          }
        }
      ]
    },

    {
      "clientId": "oauth2-playbook-mcp-inventory",
      "description": "Confidential client used by the MCP Inventory server to perform token exchange. Receives user tokens from the AI agent and exchanges them for api:inventory:* scoped tokens targeting the resource server.",
      "enabled": true,
      "publicClient": false,
      "secret": "secret",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "bearerOnly": false,
      "defaultClientScopes": [
        "basic",
        "profile",
        "openid"
      ],
      "optionalClientScopes": [
        "api:inventory:events:read",
        "api:inventory:tickets:read",
        "api:inventory:reservations:write"
      ],
      "attributes": {
        "use.refresh.tokens": "true",
        "oauth2.token.exchange.grant.enabled": "true",
        "standard.token.exchange.enabled": "true"
      },
      "protocolMappers": [
        {
          "name": "inventory-resource-server-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "oauth2-playbook-inventory-resource-server",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "introspection.token.claim": "true",
            "userinfo.token.claim": "false"
          }
        }
      ]
    },

    {
      "clientId": "oauth2-playbook-inventory-resource-server",
      "description": "Bearer-only resource server that validates exchanged tokens. Enforces api:inventory:* scopes per endpoint via @ScopesAllowed. Audience must match this client-id.",
      "enabled": true,
      "publicClient": false,
      "secret": "secret",
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "defaultClientScopes": [
        "basic",
        "profile",
        "openid"
      ],
      "optionalClientScopes": [
        "api:inventory:events:read",
        "api:inventory:tickets:read",
        "api:inventory:reservations:write"
      ]
    }

  ],

  "clientScopes": [

    {
      "name": "basic",
      "description": "OpenID Connect scope for basic claims",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "auth_time",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usersessionmodel-note-mapper",
          "consentRequired": false,
          "config": {
            "user.session.note": "AUTH_TIME",
            "introspection.token.claim": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "auth_time",
            "jsonType.label": "long"
          }
        },
        {
          "name": "sub",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-sub-mapper",
          "consentRequired": false,
          "config": {
            "introspection.token.claim": "true",
            "access.token.claim": "true"
          }
        }
      ]
    },

    {
      "name": "web-origins",
      "description": "Adds allowed web origins to the access token",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "consent.screen.text": "",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "allowed web origins",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-allowed-origins-mapper",
          "consentRequired": false,
          "config": {}
        }
      ]
    },

    {
      "name": "profile",
      "description": "OpenID Connect built-in scope: profile",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "consent.screen.text": "${profileScopeConsentText}",
        "display.on.consent.screen": "true"
      },
      "protocolMappers": [
        {
          "name": "given name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "firstName",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "given_name",
            "jsonType.label": "String",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "family name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "lastName",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "family_name",
            "jsonType.label": "String",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "full name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-full-name-mapper",
          "consentRequired": false,
          "config": {
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "username",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "preferred_username",
            "jsonType.label": "String",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },

    {
      "name": "openid",
      "description": "OpenID Connect built-in scope: openid",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": []
    },

    {
      "name": "mcp:events:read",
      "description": "Allows AI agent to invoke listTopEventsByCity MCP tool. Granted to inventory-full-access and inventory-readonly roles.",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true"
      },
      "protocolMappers": []
    },

    {
      "name": "mcp:tickets:read",
      "description": "Allows AI agent to invoke availableTicketsAndPrice MCP tool. Granted to inventory-full-access and inventory-readonly roles.",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true"
      },
      "protocolMappers": []
    },

    {
      "name": "mcp:reservations:write",
      "description": "Allows AI agent to invoke reserveEvent MCP tool. Restricted to inventory-full-access role only.",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true"
      },
      "protocolMappers": []
    },

    {
      "name": "api:inventory:events:read",
      "description": "Access to GET /api/inventory/events. Issued via token exchange. Enforced by @ScopesAllowed. Granted to full-access and readonly roles.",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true"
      },
      "protocolMappers": []
    },

    {
      "name": "api:inventory:tickets:read",
      "description": "Access to GET /api/inventory/events/{id}/tickets. Issued via token exchange. Enforced by @ScopesAllowed. Granted to full-access and readonly roles.",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true"
      },
      "protocolMappers": []
    },

    {
      "name": "api:inventory:reservations:write",
      "description": "Access to POST /api/inventory/reservations. Issued via token exchange. Enforced by @ScopesAllowed. Restricted to inventory-full-access role only.",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true"
      },
      "protocolMappers": []
    }

  ],

  "defaultOptionalClientScopes": [
    "offline_access"
  ],

  "browserSecurityHeaders": {
    "contentSecurityPolicyReportOnly": "",
    "xContentTypeOptions": "nosniff",
    "referrerPolicy": "no-referrer",
    "xRobotsTag": "none",
    "xFrameOptions": "SAMEORIGIN",
    "contentSecurityPolicy": "frame-src 'self'; frame-ancestors 'self'; object-src 'none';",
    "xXSSProtection": "1; mode=block",
    "strictTransportSecurity": "max-age=31536000; includeSubDomains"
  },

  "scopeMappings": [
    {
      "clientScope": "mcp:events:read",
      "roles": [
        "oauth2-playbook-inventory-full-access",
        "oauth2-playbook-inventory-readonly"
      ]
    },
    {
      "clientScope": "mcp:tickets:read",
      "roles": [
        "oauth2-playbook-inventory-full-access",
        "oauth2-playbook-inventory-readonly"
      ]
    },
    {
      "clientScope": "mcp:reservations:write",
      "roles": [
        "oauth2-playbook-inventory-full-access"
      ]
    },
    {
      "clientScope": "api:inventory:events:read",
      "roles": [
        "oauth2-playbook-inventory-full-access",
        "oauth2-playbook-inventory-readonly"
      ]
    },
    {
      "clientScope": "api:inventory:tickets:read",
      "roles": [
        "oauth2-playbook-inventory-full-access",
        "oauth2-playbook-inventory-readonly"
      ]
    },
    {
      "clientScope": "api:inventory:reservations:write",
      "roles": [
        "oauth2-playbook-inventory-full-access"
      ]
    }
  ],

  "roles": {
    "realm": [
      {
        "name": "oauth2-playbook-inventory-full-access",
        "clientRole": false,
        "description": "Full inventory access. Grants all mcp:* and api:inventory:* scopes including reservations:write. Assigned to demo user.",
        "composite": false,
        "attributes": {}
      },
      {
        "name": "oauth2-playbook-inventory-readonly",
        "clientRole": false,
        "description": "Read-only inventory access. Grants events:read and tickets:read scopes only. Does NOT grant reservations:write. Assigned to demo-readonly user for 403 testing.",
        "composite": false,
        "attributes": {}
      }
    ]
  },

  "users": [
    {
      "username": "demo",
      "enabled": true,
      "email": "demo@oauth2-playbook.dev",
      "firstName": "Demo",
      "lastName": "User",
      "attributes": {
        "department": "Technology",
        "location": "HQ"
      },
      "credentials": [
        {
          "type": "password",
          "value": "demo123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "oauth2-playbook-inventory-full-access"
      ]
    },
    {
      "username": "demo-readonly",
      "enabled": true,
      "email": "demo-readonly@oauth2-playbook.dev",
      "firstName": "Demo",
      "lastName": "Readonly",
      "attributes": {
        "department": "Technology",
        "location": "HQ"
      },
      "credentials": [
        {
          "type": "password",
          "value": "demo123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "oauth2-playbook-inventory-readonly"
      ]
    }
  ]
}